# auto-routines: this repo IS the skill, so we ignore typical dev cruft only.
__pycache__/
*.pyc
.DS_Store
.venv/
venv/
node_modules/

# This repo self-hosts auto-routines (see .iteration/config.yaml).
# Track configuration + history; ignore ephemeral runtime artifacts.
/.iteration/*
!/.iteration/config.yaml
!/.iteration/goal.md
!/.iteration/history/
!/.iteration/checkpoints.md
/.iteration/log.jsonl
/.iteration/hook-output.log
/.iteration/evolve_requests.jsonl
/.iteration/plan.txt
/.iteration/proposals/
/.iteration/digests/
/.claude/settings.local.json

# Worktrees spawned by Claude Code's spawn_task / Task tool — these
# are independent git repos checked out into the host repo; never
# commit them.
/.claude/worktrees/
