# auto-routines: this repo IS the skill, so we ignore typical dev cruft only.
__pycache__/
*.pyc
.DS_Store
.venv/
venv/
node_modules/

# This repo self-hosts auto-routines (see .iteration/config.yaml).
# Track configuration + history; ignore ephemeral runtime artifacts.
/.iteration/*
!/.iteration/config.yaml
# PRD #10 Module 5 — runtime ledger committed back by GHA after each tick
!/.iteration/state.json
!/.iteration/goal.md
!/.iteration/history/
!/.iteration/checkpoints.md
/.iteration/log.jsonl
/.iteration/hook-output.log
/.iteration/evolve_requests.jsonl
/.iteration/plan.txt
/.iteration/proposals/
/.iteration/digests/
/.claude/settings.local.json

# Worktrees spawned by Claude Code's spawn_task / Task tool
/.claude/worktrees/
# Lockfile written by the scheduled-tasks MCP
/.claude/scheduled_tasks.lock
