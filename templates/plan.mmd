%% .iteration/plan.mmd — generated by auto-routines
%% Rendered fresh after every init, evolve, plan, and revert.
%% Shows: meta-agent, today's scheduled triggers, hooks, and current goal.

flowchart TD
  classDef meta fill:#f9f,stroke:#333,stroke-width:2px;
  classDef routine fill:#bbf,stroke:#333;
  classDef trigger fill:#dfd,stroke:#333;
  classDef failed fill:#fbb,stroke:#900;

  GOAL["Goal: {{goal}}<br/>Mode: {{mode}}"]:::meta
  META["Meta-routine /auto-routines evolve<br/>next: {{meta_next_run}}"]:::meta

  GOAL --> META

  %% For each routine, the renderer emits a trigger node and a routine node:
  %% T_<id>["<cron / event>"] --> R_<id>["<purpose>"]:::routine
  %% META -.->|may add/remove| R_<id>

  %% Example (replaced at render time):
  T_pr_ci_watcher["every 30 min"]:::trigger --> R_pr_ci_watcher["pr-ci-watcher<br/>comment on PRs"]:::routine
  META -.->|may tune| R_pr_ci_watcher

  T_daily_digest["18:00 daily"]:::trigger --> R_daily_digest["daily-digest<br/>summary"]:::routine
  META -.->|may tune| R_daily_digest
