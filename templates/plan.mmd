%% .iteration/plan.mmd — generated by auto-routines
%% Rendered fresh after every init, evolve, plan, and revert.
%% Shows: meta-agent, today's scheduled triggers, hooks, and current goal.

flowchart TD
  classDef node fill:#fff,stroke:#000,color:#000

  GOAL["Goal: {{goal}}<br/>Mode: {{mode}}"]:::node
  META["Meta-routine /auto-routines evolve<br/>next: {{meta_next_run}}"]:::node

  GOAL --> META

  %% For each routine, the renderer emits a trigger node and a routine node:
  %% T_<id>["<cron / event>"] --> R_<id>["<purpose>"]:::node
  %% META -.->|may add/remove| R_<id>

  %% Example (replaced at render time):
  T_pr_ci_watcher["every 30 min"]:::node --> R_pr_ci_watcher["pr-ci-watcher<br/>comment on PRs"]:::node
  META -.->|may tune| R_pr_ci_watcher

  T_daily_digest["18:00 daily"]:::node --> R_daily_digest["daily-digest<br/>summary"]:::node
  META -.->|may tune| R_daily_digest
